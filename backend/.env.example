# Pizza Denfert — Loyalty backend environment (SHARED with the customer app).
#
# Copy to `backend/.env` and fill in real values on the server. NEVER commit
# `.env` (see .gitignore). Real production values live in the OVH/Hetzner
# server's local backend/.env only.
#
# ---- REQUIRED ---------------------------------------------------------------
MONGO_URL="mongodb://127.0.0.1:27017"
DB_NAME="pizzadenfert"
# Generate with: openssl rand -hex 32
JWT_SECRET="replace-me-with-64-hex-chars"

# ---- SUPABASE (menu CMS) ----------------------------------------------------
# The customer menu is served from Supabase (PostgreSQL) — same project is
# consumed by BOTH apps (customer-facing site + loyalty admin CMS).
# New project (2026-06-30 migration): fuxyinngmdzzoumloenv
SUPABASE_URL="https://fuxyinngmdzzoumloenv.supabase.co"
# Server-side only (keep secret; used for CMS write endpoints).
SUPABASE_SERVICE_ROLE_KEY=""
# The anon key is safe to expose in the FRONTEND (EXPO_PUBLIC_SUPABASE_ANON_KEY).
# Kept here for reference / SSR use only.
SUPABASE_ANON_KEY=""

# ---- OTP / SMS — OPTIONAL (empty SMS_PROVIDER = DEMO MODE) ------------------
SMS_PROVIDER=""
OTP_DEMO_MODE="true"
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""
OVH_APP_KEY=""
OVH_APP_SECRET=""
OVH_CONSUMER_KEY=""
OVH_SMS_SERVICE=""
OVH_SMS_SENDER=""

# ---- Web Push / VAPID — OPTIONAL --------------------------------------------
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_CONTACT="mailto:contact@pizzadenfert.fr"

# ---- Emergent native push — OPTIONAL ----------------------------------------
# Leave as "placeholder" for self-hosted deployments (no-ops silently).
EMERGENT_PUSH_KEY="placeholder"
