# Pizza Denfert — Loyalty tablet / Admin CMS (Expo) — example env config.
#
# Copy to `frontend/.env` and adjust for your environment. The loyalty/admin
# frontend shares the SAME backend and Supabase project as the customer app.
#
# Production (default):
EXPO_PUBLIC_BACKEND_URL=https://loyalty.pizzadenfert.fr

# ---- Supabase (menu CMS) ----------------------------------------------------
# Same Supabase project used by the customer app. New project (2026-06-30):
EXPO_PUBLIC_SUPABASE_URL=https://fuxyinngmdzzoumloenv.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# ---- Local dev (uncomment when running the loyalty backend locally) --------
# EXPO_PUBLIC_BACKEND_URL=http://localhost:8001
