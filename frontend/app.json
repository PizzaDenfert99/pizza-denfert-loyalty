{
  "expo": {
    "name": "Pizza Denfert",
    "slug": "frontend",
    "version": "1.3.0",
    "orientation": "default",
    "icon": "./assets/images/staff-variant/icon.png",
    "scheme": "frontend",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Scan customer loyalty QR codes",
        "NSPhotoLibraryUsageDescription": "Select photos for menu items",
        "NSPhotoLibraryAddUsageDescription": "Save edited menu photos"
      },
      "bundleIdentifier": "fr.pizzadenfert.loyalty"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/staff-variant/adaptive-icon.png",
        "backgroundColor": "#000"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.VIBRATE",
        "android.permission.WAKE_LOCK",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.VIBRATE",
        "android.permission.WAKE_LOCK",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "fr.pizzadenfert.loyalty"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Scan customer loyalty QR codes"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Select photos for menu items",
          "cameraPermission": "Take a photo of a menu dish"
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#D4AF37",
          "defaultChannel": "reservations"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000"
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/64ab81bf-cf15-46ed-af92-3c1d6089e240"
    },
    "extra": {
      "variant": "loyalty",
      "buildLabel": "loyalty",
      "router": {},
      "eas": {
        "projectId": "64ab81bf-cf15-46ed-af92-3c1d6089e240"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/64ab81bf-cf15-46ed-af92-3c1d6089e240"
    }
  }
}
